# Copy this file to .env and fill in your values
# Never commit .env to version control

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# DataForSEO (https://dataforseo.com)
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# Apify (https://apify.com)
APIFY_API_TOKEN=your_apify_token_here

# Unsplash (https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Ideogram - optional, used as image fallback (https://ideogram.ai)
IDEOGRAM_API_KEY=

# WordPress
# WP_APP_PASSWORD: generate at yoursite.com/wp-admin -> Users -> Profile -> Application Passwords
WP_URL=https://yourblog.com
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Database
DB_PATH=pipeline.db

# Pipeline Settings
AUTO_PUBLISH=false           # Set to true only after reviewing article quality manually
MIN_SEARCH_VOLUME=500        # Minimum monthly searches to accept a keyword
MAX_KEYWORD_DIFFICULTY=60    # 0-100 scale, lower = easier to rank for
ARTICLES_PER_DAY=5           # Max articles generated per pipeline run
